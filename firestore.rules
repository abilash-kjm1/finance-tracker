rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only these Google accounts may use the app at all, and each can
    // only read/write their own data. Keep this list in sync with
    // ALLOWED_EMAILS in js/app.js.
    function isAllowedUser() {
      return request.auth != null &&
        request.auth.token.email in [
          "abilashabilash009@gmail.com"
        ];
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isAllowedUser() && request.auth.uid == userId;
    }
  }
}
